Network latency

Modify compose-test-net 

services:
  orderer.example.com:
    container_name: orderer.example.com
    image: hyperledger/fabric-orderer:latest
    cap_add:
      - NET_ADMIN
      - SYS_ADMIN

Install dependency

for c in orderer.example.com peer0.farmers.example.com peer0.aggregators.example.com peer0.retailers.example.com peer0.consumers.example.com peer0.bank.example.com; do
  echo "===== Installing tc on $c ====="
  docker exec $c bash -c "apt update && apt install -y iproute2 iputils-ping"
done

Apply latency with jitter and packet loss

for c in peer0.farmers.example.com peer0.aggregators.example.com peer0.retailers.example.com peer0.consumers.example.com peer0.bank.example.com; do
  echo "===== Applying latency on $c ====="
  docker exec $c tc qdisc add dev eth0 root netem delay 50ms 10ms loss 1%
done

Remove Latency

for c in peer0.farmers.example.com peer0.aggregators.example.com peer0.retailers.example.com peer0.consumers.example.com peer0.bank.example.com; do
  echo "===== Removing latency on $c ====="
  docker exec $c tc qdisc del dev eth0 root
done


Verfy
for c in peer0.farmers.example.com peer0.aggregators.example.com peer0.retailers.example.com peer0.consumers.example.com peer0.bank.example.com; do
  echo "===== Checking $c ====="
  docker exec $c tc qdisc show dev eth0
done


Check network latency
tc qdisc show dev eth0
